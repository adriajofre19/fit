---
import '../styles/global.css';
import { Nav } from '../components/Nav';

interface Props {
  title?: string;
  currentPath: string;
}

const { title = 'Mi Rutina', currentPath } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#ffffff" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="bg-background text-foreground">
    <Nav currentPath={currentPath} client:load />
    <div class="lg:pl-56 min-h-dvh pb-[calc(4.5rem+env(safe-area-inset-bottom))] lg:pb-8">
      <main class="mx-auto max-w-3xl px-4 py-6 lg:py-8">
        <slot />
      </main>
    </div>
  </body>
</html>
